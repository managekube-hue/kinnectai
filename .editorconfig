root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.go]
indent_size = 4
indent_style = tab
max_line_length = 120

[*.{ts,tsx,js,jsx,json,json5,yaml,yml,toml}]
indent_size = 2

[*.py]
indent_size = 4

[*.md]
max_line_length = 100
trim_trailing_whitespace = false

[*.{sql,cypher,cql}]
indent_size = 2
keyword_case = upper
