# ─────────────────────────────────────────────
# KinnectAI Backend — Environment Configuration
# Copy to .env and fill in real values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────

# Server
PORT=8080
ENV=development

# JWT
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_MIN_32_CHARS
JWT_EXPIRY_HOURS=72

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=kinnect
POSTGRES_PASSWORD=kinnect_dev_password
POSTGRES_DB=kinnectai
POSTGRES_SSL_MODE=disable

# Neo4j (biological graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=kinnect_neo4j_password

# Redis (Kin Score cache + session store)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Astra (behavioral + event store)
ASTRA_DB_ID=013e8df5-60f5-43c5-ae46-16d43a56f1a4
ASTRA_REGION=us-east-2
ASTRA_KEYSPACE=Kinnect_AI
ASTRA_TOKEN=REPLACE_WITH_ASTRA_TOKEN

# GetStream
GETSTREAM_API_KEY=9mjjuzzlisj
GETSTREAM_SECRET=d3cjy685ds5ffrnj8ayvq47ng9rjav4f3rfnfn3z98pbuuth6g486uyw4m7d85uc
GETSTREAM_APP_ID=1444256
GETSTREAM_REGION=us-ohio

# Sequencing.com (DNA)
SEQUENCING_API_KEY=REPLACE_WITH_SEQUENCING_API_KEY
SEQUENCING_BASE_URL=https://api.sequencing.com

# LexisNexis (Identity Layer 1)
LEXISNEXIS_API_KEY=REPLACE_WITH_LEXISNEXIS_KEY
LEXISNEXIS_SECRET=REPLACE_WITH_LEXISNEXIS_SECRET
LEXISNEXIS_BASE_URL=https://risk.api.lexisnexis.com

# Whitepages Pro (Identity Layer 1)
WHITEPAGES_API_KEY=REPLACE_WITH_WHITEPAGES_KEY

# AWS S3 (media storage)
AWS_ACCESS_KEY_ID=REPLACE_WITH_AWS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_AWS_SECRET
AWS_REGION=us-east-1
S3_BUCKET_MEDIA=kinnectai-media
S3_BUCKET_DNA_COLD=kinnectai-dna-glacier

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
