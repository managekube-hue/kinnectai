{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "es5",
  "tabWidth": 2,
  "printWidth": 100,
  "endOfLine": "lf",
  "arrowParens": "always",
  "bracketSpacing": true,
  "overrides": [
    {
      "files": "*.graphql",
      "options": { "printWidth": 120 }
    },
    {
      "files": "*.avsc",
      "options": { "parser": "json5" }
    }
  ]
}
